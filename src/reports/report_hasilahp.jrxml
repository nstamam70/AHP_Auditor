	<queryString>
		<![CDATA[SELECT k.kode_kriteria, k.nama_kriteria,
                   h.bobot_prioritas, h.lambda_maks,
                   h.consistency_index, h.consistency_ratio,
                   h.keterangan_cr, h.tanggal_hitung
            FROM hasil_ahp h
            JOIN kriteria k ON h.id_kriteria = k.id_kriteria
            ORDER BY h.bobot_prioritas DESC]]>
	</queryString>
