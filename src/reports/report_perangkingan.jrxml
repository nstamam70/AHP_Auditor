	<queryString>
		<![CDATA[SELECT hp.ranking, t.kode_teknisi, t.nama_teknisi,
                   hp.nilai_akhir, hp.keterangan, hp.tanggal_ranking
            FROM hasil_perankingan hp
            JOIN teknisi t ON hp.id_teknisi = t.id_teknisi
            ORDER BY hp.ranking ASC]]>
	</queryString>
